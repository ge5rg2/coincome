# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/coincome

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_guild_id  # 슬래시 커맨드 즉시 동기화용 (개발 시)

# Upbit (서버 기본 키 - 사용자별 키는 DB 저장)
UPBIT_ACCESS_KEY=your_upbit_access_key
UPBIT_SECRET_KEY=your_upbit_secret_key

# TossPayments
TOSS_CLIENT_KEY=your_toss_client_key
TOSS_SECRET_KEY=your_toss_secret_key

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DASHBOARD_BASE_URL=http://localhost:8000

# Security
SECRET_KEY=change_this_to_a_random_secret_key_in_production
# 키 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_base64_key_here
# 업비트 API 키 IP 화이트리스트에 등록할 서버 공인 IP
SERVER_IP=0.0.0.0
